{
	"name": "domru-js",
	"version": "0.1.0",
	"description": "Неофициальный TypeScript-клиент для API умного дома Dom.ru / Proptech — домофоны, камеры, события и другое.",
	"author": "S0yora",
	"homepage": "https://github.com/S0yora/domru-js#readme",
	"bugs": {
		"url": "https://github.com/S0yora/domru-js/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/S0yora/domru-js.git"
	},
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"sideEffects": false,
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "bun build src/index.ts --outdir dist --target node && bun run build:types",
		"build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
		"typecheck": "tsc --noEmit",
		"check": "bun run lint && bun run typecheck && bun run test",
		"lint": "eslint src/**/*.ts",
		"lint:fix": "eslint src/**/*.ts --fix",
		"format": "prettier --write src/**/*.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"clean": "rm -rf dist",
		"dev": "tsc --watch --emitDeclarationOnly --declaration --outDir dist",
		"prepublishOnly": "bun run clean && bun run build && bun run check",
		"release:dry": "npm publish --dry-run",
		"release:npm": "npm publish --access public"
	},
	"keywords": [
		"domru",
		"dom.ru",
		"умный-дом",
		"домофон",
		"proptech",
		"iot",
		"api-client",
		"typescript"
	],
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"axios": "^1.7.0"
	},
	"devDependencies": {
		"typescript": "^5.7.0",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"@typescript-eslint/parser": "^7.0.0",
		"eslint": "^8.57.0",
		"eslint-config-prettier": "^9.1.0",
		"prettier": "^3.2.0",
		"vitest": "^2.0.0"
	}
}
